    for _, v in pairs(livingChildren) do
        if v:FindFirstChild("HumanoidRootPart") then
            if mobSelectionTable[v.Name] then
                if game:GetService("Players").LocalPlayer.PlayerGui.UI.Gameplay.Moves["Rush Attack"].Cooldown.Meter.BackgroundTransparency == 1 then
                    if not LocalPlayer.Character:FindFirstChild('DamageIndicator') then
                    task.spawn(function()
                        local args = {[1] = "MouseButton1"}
                        game:GetService("ReplicatedStorage"):WaitForChild("ReplicatedModules"):WaitForChild("KnitPackage"):WaitForChild("Knit"):WaitForChild("Services"):WaitForChild("MoveInputService"):WaitForChild("RF"):WaitForChild("FireInput"):InvokeServer(unpack(args))
                        task.wait(0.125)
                    end)
                        LocalPlayer.Character.HumanoidRootPart.CFrame = v:FindFirstChild("HumanoidRootPart").CFrame * CFrame.new(0, 4, MobDistance)
                       game.Workspace:FindFirstChild("TeleportPart").CFrame = LocalPlayer.Character.HumanoidRootPart.CFrame * CFrame.new(0, -3, 0)                
                    else
                        LocalPlayer.Character.HumanoidRootPart.CFrame = v:FindFirstChild("HumanoidRootPart").CFrame * CFrame.new(0, 150, MobDistance)
                        game.Workspace:FindFirstChild("TeleportPart").CFrame = LocalPlayer.Character.HumanoidRootPart.CFrame * CFrame.new(0, -3, 0)
                    end
                else
                    -- move to mob position
                    LocalPlayer.Character.HumanoidRootPart.CFrame = v:FindFirstChild("HumanoidRootPart").CFrame * CFrame.new(0, 150, MobDistance)
                    game.Workspace:FindFirstChild("TeleportPart").CFrame = LocalPlayer.Character.HumanoidRootPart.CFrame * CFrame.new(0, -3, 0)
