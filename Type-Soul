local function TpToNearestMob()
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then
        print("Character not found!")
        return
    end
    
    -- Check if Entities folder exists
    if not workspace:FindFirstChild("Entities") then
        print("Entities folder not found!")
        return
    end
    
    local playerPosition = character.HumanoidRootPart.Position
    local closestMob = nil
    local shortestDistance = math.huge
    
    -- Check if we can search for mobs (player should exist in Entities for this game)
    if workspace.Entities:FindFirstChild(LocalPlayer.Name) then
        -- Loop through entities to find closest mob
        for i, v in ipairs(workspace.Entities:GetChildren()) do
            -- Skip if it's the local player or doesn't have required components
            if v.Name ~= LocalPlayer.Name and v:FindFirstChild("Humanoid") and v:FindFirstChild("HumanoidRootPart") then
                -- Check if it's NOT a player (only NPCs/mobs)
                local isPlayer = Players:GetPlayerFromCharacter(v)
                if not isPlayer and v.Humanoid.Health > 0 then
                    local distance = (v.HumanoidRootPart.Position - playerPosition).Magnitude
                    
                    if distance < shortestDistance then
                        shortestDistance = distance
                        closestMob = v
                    end
                                    end
            end
        end
        
        -- Tween to the closest mob (smooth movement)
        if closestMob then            
            local targetCFrame = closestMob.HumanoidRootPart.CFrame * CFrame.new(0, dintanceuppervaule, 0)       
            -- Calculate duration based on distance and speed
            local speed = 50 -- Speed in studs per second
            local distance = (targetCFrame.Position - playerPosition).Magnitude
            local duration = distance / speed
            
            local tweenInfo = TweenInfo.new(
                duration, -- Duration based on speed
                Enum.EasingStyle.Quad,
                Enum.EasingDirection.Out
            )
            
            local tween = TweenService:Create(
                character.HumanoidRootPart,
                tweenInfo,
                {CFrame = targetCFrame}
            )
            tween:Play()
            game.Workspace:FindFirstChild("TeleportPart").CFrame = LocalPlayer.Character.HumanoidRootPart.CFrame * CFrame.new(0, -3, 0)                
        else
        end
    else
    end
end
